{
  "$schema": "https://raw.githubusercontent.com/code-yeongyu/oh-my-openagent/dev/assets/oh-my-opencode.schema.json",
  "instructions": ["./AGENTS.md"],
  "loop_max_iterations": 20,
  "ralph_loop": {
    "enabled": false
  },
  "experimental": {
    "task_system": false
  },
  "disabled_mcps": ["ast_grep"],
  "agents": {
    "sisyphus": {
      "model": "openrouter/google/gemini-2.0-flash-001",
      "maxTokens": 8192,
      "permission": {
        "external_directory": "deny",
        "task": "allow",
        "edit": "allow",
        "bash": "allow"
      },
      "prompt_append": "For plan.json: ignore lsp_diagnostics; run lint_plan_json until PASS before finishing structure."
    },
    "prometheus": {
      "model": "openrouter/google/gemini-2.0-flash-001",
      "maxTokens": 8192,
      "permission": {
        "external_directory": "deny",
        "task": "allow",
        "edit": "allow"
      },
      "prompt_append": "PLAN only: edit .omo/plans/*.md with Atlas delegations (where to look). Do NOT spawn task() or background subagents during planning — Atlas runs explore/librarian later."
    },
    "atlas": {
      "model": "openrouter/google/gemini-2.0-flash-001",
      "maxTokens": 8192,
      "permission": {
        "external_directory": "deny",
        "task": "allow",
        "edit": "allow"
      },
      "prompt_append": "You execute Prometheus delegations: run explore/librarian, then edit state/current/draft.md with confirmed findings. Manager said where to look; you report what was found."
    },
    "hephaestus": {
      "model": "openrouter/openai/gpt-4o-mini",
      "maxTokens": 8192,
      "permission": {
        "external_directory": "deny",
        "task": "allow",
        "edit": "allow"
      }
    },
    "oracle": {
      "model": "openrouter/openai/gpt-4o-mini",
      "maxTokens": 4096
    },
    "librarian": {
      "model": "openrouter/openai/gpt-4o-mini",
      "maxTokens": 4096,
      "permission": {
        "edit": "deny",
        "bash": "deny",
        "external_directory": "deny"
      }
    },
    "explore": {
      "model": "openrouter/openai/gpt-4o-mini",
      "maxTokens": 4096,
      "permission": {
        "edit": "deny",
        "bash": "deny",
        "external_directory": "deny"
      }
    }
  }
}
